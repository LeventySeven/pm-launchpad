# ============================================================================
# Prediction Market Environment Variables
# ============================================================================
# Copy this file to .env.local (local development) or add variables to Vercel
# dashboard (project settings → Environment Variables) for deployment.
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
# Never commit actual .env files to git - they contain secrets!

# ============================================================================
# Supabase (Database & Auth)
# ============================================================================

# [REQUIRED] Supabase Project URL
# Get from: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase Anonymous Key (safe to expose to browser)
# Get from: Supabase Dashboard → Project Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# [REQUIRED] Supabase Service Role Key (server-side only, KEEP SECRET!)
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# NEVER expose this to the browser or commit to git
# Used by backend for admin operations (bypassing RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# Authentication (JWT)
# ============================================================================

# [REQUIRED] JWT Secret for custom auth tokens (min 32 characters)
# Generate with: openssl rand -hex 32
# Used for signing/verifying custom authentication tokens
AUTH_JWT_SECRET=your-random-secret-here-min-32-chars

# ============================================================================
# Solana Configuration (DevNet for Testing)
# ============================================================================

# [REQUIRED] Solana Cluster: "devnet" | "testnet" | "mainnet-beta"
# Use "devnet" for testing on Vercel
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# [OPTIONAL] Custom Solana RPC Endpoint
# DevNet defaults to https://api.devnet.solana.com if not set
# For production/mainnet, use Helius, QuickNode, or Alchemy RPC for better reliability
# Example (Helius DevNet): https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Example (QuickNode): https://your-endpoint.solana-devnet.quiknode.pro/YOUR_KEY/
NEXT_PUBLIC_SOLANA_RPC_URL=

# [REQUIRED] Solana Program ID (deployed Anchor program public key)
# After running `anchor deploy`, get from:
#   - Terminal output: "Program Id: ..."
#   - anchor/Anchor.toml [programs.devnet] or [programs.mainnet]
# Format: Base58 string (e.g., HGDLzy31GLgckzH2hHeTKaYsxDCuCoAXDtUDsJvpZ1JY)
NEXT_PUBLIC_SOLANA_PROGRAM_ID=

# [REQUIRED] USDC Mint Address (SPL Token mint public key)
# DevNet: Create via `bun scripts/solana/create-devnet-usdc-mint.ts`
# Mainnet: Official USDC = EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Format: Base58 string
NEXT_PUBLIC_SOLANA_USDC_MINT=

# ============================================================================
# Solana Deployment Configuration (For anchor deploy)
# ============================================================================

# [REQUIRED FOR DEPLOYMENT] Deployer Keypair Path (private key - KEEP SECRET!)
# Path to the JSON keypair file used to deploy the Anchor program
# Generate with: solana-keygen new --no-bip39-passphrase -o anchor/deployer-keypair.json
# Fund with: solana airdrop 2 <deployer-address> --url devnet
# Format: Relative path from project root (e.g., ./anchor/deployer-keypair.json)
# This is ONLY needed for deployment, NOT for runtime on Vercel
# NEVER commit this file to git - contains private key material!
SOLANA_DEPLOYER_KEYPAIR_PATH=./anchor/deployer-keypair.json

# [OPTIONAL] Deployer Address (public key, for reference/verification)
# Get from: solana-keygen pubkey anchor/deployer-keypair.json
# Useful for checking balance, funding with airdrop, etc.
# Format: Base58 string (e.g., YourDeployerAddress1234567890123456789012345678)
SOLANA_DEPLOYER_ADDRESS=

# ============================================================================
# Solana Backend Configuration (Server-Side Only - Runtime)
# ============================================================================

# [OPTIONAL] Backend Solana cluster (can use without NEXT_PUBLIC_ prefix)
# Defaults to NEXT_PUBLIC_SOLANA_CLUSTER if not set
SOLANA_CLUSTER=devnet

# [OPTIONAL] Backend RPC endpoint (can differ from frontend if needed)
SOLANA_RPC_URL=

# [OPTIONAL] Backend program ID (defaults to NEXT_PUBLIC_SOLANA_PROGRAM_ID)
SOLANA_PROGRAM_ID=

# [OPTIONAL] Backend USDC mint (defaults to NEXT_PUBLIC_SOLANA_USDC_MINT)
SOLANA_USDC_MINT=

# [REQUIRED] Quote Authority Public Key (backend signing keypair public key)
# This is the PUBLIC KEY of the keypair used by backend to sign bet/sell transactions
# Generate keypair: solana-keygen new --no-bip39-passphrase -o anchor/quote-authority.json
# Get public key: solana-keygen pubkey anchor/quote-authority.json
# Format: Base58 string (e.g., YourBackendPubkey1234567890123456789012345678)
# This must match the quote_authority set in the on-chain Config account
SOLANA_QUOTE_AUTHORITY=

# [REQUIRED] Quote Authority Keypair Path (PRIVATE KEY - KEEP SECRET!)
# Path to the JSON keypair file used by backend to sign bet/sell transactions
# For local dev: ./anchor/quote-authority.json
# For Vercel: Upload the keypair content as a secret environment variable
#   OR use Vercel Secrets Manager and reference it here
# Format: Absolute path or relative path from project root
# Example (local): ./anchor/quote-authority.json
# Example (Vercel): Use Vercel environment variable for the JSON array content
# NEVER commit this file to git - contains private key material!
SOLANA_QUOTE_AUTHORITY_KEYPAIR=./anchor/quote-authority.json

# ============================================================================
# Solana USDC Mint Creation (Optional)
# ============================================================================

# [OPTIONAL] Initial USDC supply for devnet mint (in major units, e.g., 10000 = 10,000 USDC)
# Used when running: bun scripts/solana/create-devnet-usdc-mint.ts
# Defaults to 10000 if not set
SOLANA_DEVNET_USDC_INITIAL_SUPPLY=10000

# [OPTIONAL] Keypair path for creating devnet USDC mint
# Defaults to ~/.config/solana/id.json if not set
# Used by: bun scripts/solana/create-devnet-usdc-mint.ts
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# ============================================================================
# Webhooks & Indexing (Optional)
# ============================================================================

# [OPTIONAL] Helius Webhook Secret (for secure webhook verification)
# Generate with: openssl rand -hex 32
# Configure the same secret in your Helius webhook dashboard
# Used for verifying incoming webhook requests from Helius indexer
HELIUS_WEBHOOK_SECRET=

# ============================================================================
# DevNet Deployment Checklist
# ============================================================================
#
# 1. ✅ Generate deployer keypair:
#    solana-keygen new --no-bip39-passphrase -o anchor/deployer-keypair.json
#
# 2. ✅ Fund deployer wallet:
#    solana airdrop 2 $(solana-keygen pubkey anchor/deployer-keypair.json) --url devnet
#
# 3. ✅ Deploy Anchor program:
#    cd anchor && anchor build && anchor deploy --provider.cluster devnet
#    → Set NEXT_PUBLIC_SOLANA_PROGRAM_ID from output
#
# 4. ✅ Create USDC mint:
#    bun scripts/solana/create-devnet-usdc-mint.ts
#    → Set NEXT_PUBLIC_SOLANA_USDC_MINT from output
#
# 5. ✅ Generate quote authority keypair:
#    solana-keygen new --no-bip39-passphrase -o anchor/quote-authority.json
#    → Set SOLANA_QUOTE_AUTHORITY from: solana-keygen pubkey anchor/quote-authority.json
#
# 6. ✅ Initialize Config PDA (run after deployment):
#    → Use Anchor client or script to call initialize_config with quote_authority
#
# 7. ✅ Set all environment variables in Vercel dashboard
#
# ============================================================================
# Vercel Deployment Notes
# ============================================================================
#
# To set environment variables in Vercel:
# 1. Go to your project in Vercel Dashboard
# 2. Navigate to: Settings → Environment Variables
# 3. Add each variable:
#    - Variable name: (e.g., NEXT_PUBLIC_SOLANA_PROGRAM_ID)
#    - Value: (the actual value)
#    - Environment: Select "Production", "Preview", and/or "Development" as needed
#
# For sensitive variables (SOLANA_QUOTE_AUTHORITY_KEYPAIR, etc.):
# - For keypair files: Store the JSON array content as an environment variable
#   Example: [123,45,67,...] (the actual array from the keypair JSON file)
# - Consider using Vercel Secrets (encrypted storage) for production
# - You may need to write the keypair content to a temp file at runtime
#
# After adding variables:
# - Redeploy your application for changes to take effect
# - Check Vercel build logs to verify variables are accessible
#
# ============================================================================
# Security Checklist
# ============================================================================
#
# ✅ NEXT_PUBLIC_* variables are exposed to browser (safe for public keys/URLs)
# ✅ Variables without NEXT_PUBLIC_ are server-side only (KEEP SECRETS PRIVATE)
# ✅ Never commit .env, .env.local, or .env.production files to git
# ✅ Never commit Solana keypair JSON files (deployer-keypair.json, quote-authority.json, etc.)
# ✅ Keep SOLANA_QUOTE_AUTHORITY_KEYPAIR secure (use Vercel Secrets for production)
# ✅ Keep SOLANA_DEPLOYER_KEYPAIR_PATH secure (only needed for deployment, not runtime)
# ✅ Keep SUPABASE_SERVICE_ROLE_KEY secure (has admin database access)
# ✅ Keep AUTH_JWT_SECRET secure (used for token signing)
# ✅ Keep HELIUS_WEBHOOK_SECRET secure (prevents webhook spoofing)
#
# ============================================================================
