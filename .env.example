# =============================================================================
# Prediction Market Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# JWT Configuration (for custom auth)
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-at-least-32-characters

# -----------------------------------------------------------------------------
# WalletConnect / Reown AppKit
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# -----------------------------------------------------------------------------
# Alchemy (Blockchain RPC & Webhooks)
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=your-alchemy-api-key
ALCHEMY_WEBHOOK_SECRET=your-alchemy-webhook-signing-key

# Full RPC URLs (alternative to using API key)
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key
ALCHEMY_MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# -----------------------------------------------------------------------------
# Smart Contract Addresses (Sepolia Testnet)
# Update after deployment
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_VAULT_ADDRESS_SEPOLIA=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS_SEPOLIA=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Smart Contract Addresses (Ethereum Mainnet)
# Update when deploying to mainnet
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_VAULT_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Contract Deployment (DO NOT COMMIT PRIVATE KEYS)
# Only needed for deploying contracts
# -----------------------------------------------------------------------------
# DEPLOYER_PRIVATE_KEY=your-deployer-wallet-private-key
# ETHERSCAN_API_KEY=your-etherscan-api-key

# -----------------------------------------------------------------------------
# Gas Reporting (optional, for development)
# -----------------------------------------------------------------------------
# REPORT_GAS=true
